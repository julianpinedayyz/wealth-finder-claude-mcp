{
  "name": "wealth-finder-mcp",
  "version": "0.1.0",
  "description": "MCP server demo for personal finance workflows backed by Supabase",
  "private": true,
  "scripts": {
    "dev:mcp": "ts-node src/mcp/server.ts",
    "logs": "bash scripts/watch-logs.sh",
    "seed:supabase": "node scripts/seed_supabase.mjs",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run tests/tools/",
    "test:watch": "vitest tests/tools/"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@supabase/supabase-js": "^2.98.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
